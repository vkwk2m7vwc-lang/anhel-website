# ─────────────────────────────────────────────────────────────
# ANHEL — local environment variables (example).
# Copy this file to .env.local and fill in the real values.
# .env.local is git-ignored; .env.local.example is committed.
# Нужно только на Этапе 7 (форма контактов) и позже.
# ─────────────────────────────────────────────────────────────

# Public site origin (used in metadata, OG, sitemap). Dev: http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://anhelspb.com

# — Stage 7: contact form —
# Resend transactional email (https://resend.com).
RESEND_API_KEY=
CONTACT_INBOX_EMAIL=info@anhelspb.com

# reCAPTCHA v3 — anti-spam on the contact form.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Telegram duplicate of every inbound request — set up via @BotFather.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# — Stage 4: CMS for projects (Sanity) —
# Create a project at https://sanity.io, then fill project id + dataset.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_READ_TOKEN=

# — Stage 8/9: Analytics —
# Yandex Metrika counter id (number only, e.g. 12345678).
NEXT_PUBLIC_YANDEX_METRIKA_ID=
